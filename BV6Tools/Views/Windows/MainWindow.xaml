<ui:FluentWindow x:Class="BV6Tools.Views.Windows.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:control="clr-namespace:BV6Tools.Views.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:local="clr-namespace:BV6Tools.Views.Windows"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding ViewModel.ApplicationTitle,
                                 Mode=OneWay}"
                 MinWidth="700"
                 MinHeight="477"
                 d:DataContext="{d:DesignInstance local:MainWindow,
                                                  IsDesignTimeCreatable=True}"
                 d:DesignHeight="450"
                 d:DesignWidth="800"
                 ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
                 ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">
    <Grid>
        <ui:NavigationView x:Name="RootNavigation"
                           Padding="42,0,42,0"
                           BreadcrumbBar="{Binding ElementName=BreadcrumbBar}"
                           FooterMenuItemsSource="{Binding ViewModel.NavigationFooter,
                                                           Mode=OneWay}"
                           FrameMargin="0,50,0,0"
                           IsBackButtonVisible="Auto"
                           IsFooterSeparatorVisible="False"
                           IsPaneToggleVisible="True"
                           IsTopSeparatorVisible="False"
                           MenuItemsSource="{Binding ViewModel.NavigationItems,
                                                     Mode=OneWay}"
                           OpenPaneLength="140"
                           PaneDisplayMode="Left"
                           SelectionChanged="RootNavigation_SelectionChanged">
            <ui:NavigationView.PaneFooter>
                <Grid Margin="0,0,0,5">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <ui:Button Grid.Row="2"
                               Padding="0"
                               HorizontalAlignment="Stretch"
                               IsHitTestVisible="False"
                               Visibility="{Binding ViewModel.IsCounterVisible,
                                                    Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:Button.Style>
                            <Style BasedOn="{StaticResource {x:Type ui:Button}}"
                                   TargetType="ui:Button">
                                <Setter Property="Appearance" Value="Success" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewModel.IsLimit}"
                                                 Value="True">
                                        <Setter Property="Appearance" Value="Danger" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       TextAlignment="Center"
                                       Visibility="{Binding ElementName=RootNavigation,
                                                            Path=IsPaneOpen,
                                                            Converter={StaticResource BooleanToVisibilityConverter},
                                                            ConverterParameter=True}">
                                <Run Text="{Binding ViewModel.Appids.Count,
                                                    Mode=OneWay}" />
                                <LineBreak />
                                -<LineBreak />
                                <Run Text="{Binding ViewModel.Settings.GreenLumaLimit,
                                                    Mode=OneWay}" /></TextBlock>
                            <TextBlock Visibility="{Binding ElementName=RootNavigation,
                                                            Path=IsPaneOpen,
                                                            Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Run Text="{Binding ViewModel.Appids.Count,
                                                    Mode=OneWay}" />
                                <Run Text="/" />
                                <Run Text="{Binding ViewModel.Settings.GreenLumaLimit,
                                                    Mode=OneWay}" /></TextBlock>
                        </StackPanel>
                    </ui:Button>
                </Grid>
            </ui:NavigationView.PaneFooter>
            <ui:NavigationView.Header>
                <StackPanel Margin="42,32,42,20">
                    <ui:BreadcrumbBar x:Name="BreadcrumbBar" />
                </StackPanel>
            </ui:NavigationView.Header>
            <ui:NavigationView.ContentOverlay>
                <Grid>
                    <ui:SnackbarPresenter x:Name="SnackbarPresenter" />
                </Grid>
            </ui:NavigationView.ContentOverlay>
        </ui:NavigationView>
        <ui:ContentDialogHost x:Name="RootContentDialog"
                              Grid.Row="0" />
        <ui:TitleBar x:Name="TitleBar"
                     Title="{Binding ViewModel.ApplicationTitle}"
                     Margin="35,0,0,0"
                     CloseWindowByDoubleClickOnIcon="False"
                     HelpClicked="TitleBar_HelpClicked"
                     MinimizeClicked="TitleBar_MinimizeClicked"
                     ShowHelp="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/bv6tools-icon-256.png" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <Grid>
                    <ui:Button HorizontalAlignment="Stretch"
                               VerticalContentAlignment="Stretch"
                               Background="Transparent"
                               BorderBrush="Transparent"
                               Command="{Binding ViewModel.ShowNotificationFlyoutCommand}"
                               FontSize="18"
                               Icon="{ui:SymbolIcon Symbol=Alert24}" />
                    <ui:InfoBadge Margin="0,-14,-14,0"
                                  Severity="Attention"
                                  Visibility="{Binding ViewModel.HasPendingChanges,
                                                       Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Value="{Binding ViewModel.PendingChangesCount}" />
                    <ui:Flyout x:Name="infoflyout"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               IsOpen="{Binding ViewModel.IsNotificationFlyoutOpen,
                                                Mode=TwoWay}"
                               Placement="Bottom">
                        <StackPanel Margin="0,0,0,4">
                            <ui:Card Visibility="{Binding ViewModel.HasPendingChanges,
                                                          Converter={StaticResource BooleanToVisibilityConverter},
                                                          ConverterParameter=true}">
                                <ui:TextBlock Text="Must've been the wind..." />
                            </ui:Card>
                            <ui:Card Margin="0,0,0,4"
                                     Visibility="{Binding ViewModel.ListHasPendingChanges,
                                                          Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <ui:TextBlock Margin="0,0,0,8"
                                                  Text="List page has unsaved changes"
                                                  TextAlignment="Center" />
                                    <ui:Button HorizontalAlignment="Stretch"
                                               Command="{Binding ViewModel.NotificationSendSaveCommand}"
                                               CommandParameter="list">
                                        <control:IconLabel Label="Save"
                                                           Symbol="Save16" />
                                    </ui:Button>
                                </StackPanel>
                            </ui:Card>
                            <ui:Card Margin="0,0,0,4"
                                     Visibility="{Binding ViewModel.DepotHasPendingChanges,
                                                          Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <ui:TextBlock Margin="0,0,0,8"
                                                  Text="Depot page has unsaved changes"
                                                  TextAlignment="Center" />
                                    <ui:Button HorizontalAlignment="Stretch"
                                               Command="{Binding ViewModel.NotificationSendSaveCommand}"
                                               CommandParameter="depot">
                                        <control:IconLabel Label="Save"
                                                           Symbol="Save16" />
                                    </ui:Button>
                                </StackPanel>
                            </ui:Card>
                            <ui:Card Margin="0,0,0,4"
                                     Visibility="{Binding ViewModel.LuaHasPendingChanges,
                                                          Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <ui:TextBlock Margin="0,0,0,8"
                                                  Text="Lua page has unsaved changes"
                                                  TextAlignment="Center" />
                                    <ui:Button HorizontalAlignment="Stretch"
                                               Command="{Binding ViewModel.NotificationSendSaveCommand}"
                                               CommandParameter="lua">
                                        <control:IconLabel Label="Save"
                                                           Symbol="Save16" />
                                    </ui:Button>
                                </StackPanel>
                            </ui:Card>
                            <ui:Card Margin="0,0,0,4"
                                     Visibility="{Binding ViewModel.TicketHasPendingChanges,
                                                          Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <ui:TextBlock Margin="0,0,0,8"
                                                  Text="Ticket page has unsaved changes"
                                                  TextAlignment="Center" />
                                    <ui:Button HorizontalAlignment="Stretch"
                                               Command="{Binding ViewModel.NotificationSendSaveCommand}"
                                               CommandParameter="ticket">
                                        <control:IconLabel Label="Save"
                                                           Symbol="Save16" />
                                    </ui:Button>
                                </StackPanel>
                            </ui:Card>
                            <ui:Card Margin="0,0,0,4"
                                     Visibility="{Binding ViewModel.SettingsHasPendingChanges,
                                                          Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <ui:TextBlock Margin="0,0,0,8"
                                                  Text="Settings page has unsaved changes"
                                                  TextAlignment="Center" />
                                    <ui:Button HorizontalAlignment="Stretch"
                                               Command="{Binding ViewModel.NotificationSendSaveCommand}"
                                               CommandParameter="settings">
                                        <control:IconLabel Label="Save"
                                                           Symbol="Save16" />
                                    </ui:Button>
                                </StackPanel>
                            </ui:Card>
                            <ui:Button Margin="0,4,0,0"
                                       HorizontalAlignment="Stretch"
                                       Command="{Binding ViewModel.NotificationSendSaveCommand}"
                                       CommandParameter="all"
                                       Visibility="{Binding ViewModel.HasPendingChanges,
                                                            Converter={StaticResource BooleanToVisibilityConverter}}">
                                <control:IconLabel Label="Save All"
                                                   Symbol="Save16" />
                            </ui:Button>
                        </StackPanel>
                    </ui:Flyout>
                </Grid>
            </ui:TitleBar.Header>
        </ui:TitleBar>
    </Grid>
</ui:FluentWindow>