<Page x:Class="BV6Tools.Views.Pages.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:control="clr-namespace:BV6Tools.Views.Controls"
      xmlns:cv="clr-namespace:BV6Tools.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:local="clr-namespace:BV6Tools.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="LibraryPage"
      d:DataContext="{d:DesignInstance local:LibraryPage,
                                       IsDesignTimeCreatable=False}"
      d:DesignHeight="1173"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Loaded="LibraryPage_Loaded"
      ScrollViewer.CanContentScroll="False"
      mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <cv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Page.Resources>
    <DockPanel>
        <DockPanel Margin="0,0,0,10"
                   HorizontalAlignment="Stretch"
                   DockPanel.Dock="Bottom">
            <DockPanel Margin="5,0"
                       DockPanel.Dock="Right"
                       Visibility="{Binding ViewModel.ViewBoxChanged,
                                            Converter={StaticResource BooleanToVisibilityConverter}}">
                <ui:Button Appearance="Primary"
                           Command="{Binding ViewModel.SaveViewBoxCommand}">
                    <control:IconLabel Label="Save"
                                       Symbol="Save16" />
                </ui:Button>
                <ui:Button Margin="8,0,0,0"
                           Appearance="Secondary"
                           Command="{Binding ViewModel.RevertViewBoxCommand}">
                    <control:IconLabel Label="Undo"
                                       Symbol="ArrowUndo16" />
                </ui:Button>
            </DockPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MaxWidth="200" />
                    <ColumnDefinition MaxWidth="200" />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,4,0">
                    <ui:TextBlock Text="Zoom" />
                    <Slider MinWidth="80"
                            Maximum="500"
                            Minimum="100"
                            Value="{Binding ViewModel.ViewBoxSize,
                                            Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Margin="0,0,4,0">
                    <ui:TextBlock Text="Spacing" />
                    <Slider MinWidth="80"
                            Maximum="40"
                            Minimum="0"
                            Value="{Binding ViewModel.ViewBoxMargin,
                                            Mode=TwoWay}" />
                </StackPanel>
            </Grid>
        </DockPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel>
                <ui:Button Grid.Column="2"
                           Margin="8,0,0,0"
                           VerticalAlignment="Stretch"
                           Click="Button_Click"
                           DockPanel.Dock="Right">
                    <control:IconLabel Label="Rescan"
                                       Symbol="ArrowClockwise24" />
                </ui:Button>
                <ui:AutoSuggestBox Icon="{ui:SymbolIcon Search24}"
                                   IsSuggestionListOpen="False"
                                   MaxSuggestionListHeight="170"
                                   OriginalItemsSource="{Binding ViewModel.Games,
                                                                 Mode=OneWay}"
                                   PlaceholderText="Appid or Game Name"
                                   Text="{Binding ViewModel.SearchText,
                                                  Mode=TwoWay,
                                                  UpdateSourceTrigger=PropertyChanged}"
                                   UseLayoutRounding="True" />
            </DockPanel>
            <ui:VirtualizingItemsControl x:Name="GamesVirtualizingItemsControl"
                                         Grid.Row="1"
                                         Margin="-42,8,-42,8"
                                         Padding="42,0,42,0"
                                         ItemsSource="{Binding ViewModel.GamesView}"
                                         VirtualizingPanel.CacheLengthUnit="Item"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         VirtualizingPanel.VirtualizationMode="Recycling">
                <ui:VirtualizingItemsControl.ItemTemplate>
                    <DataTemplate>
                        <control:GameCard AddButtonVisible="False"
                                          DownloadButtonVisible="False"
                                          Text="{Binding Name}"
                                          ViewBoxMargin="{Binding ViewModel.ViewBoxMargin,
                                                                  RelativeSource={RelativeSource AncestorType=Page}}"
                                          ViewBoxWidth="{Binding ViewModel.ViewBoxSize,
                                                                 RelativeSource={RelativeSource AncestorType=Page}}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding ViewModel.CardClickCommand,
                                                                             RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}" />
                                </i:EventTrigger>
                                <i:EventTrigger EventName="Loaded">
                                    <i:InvokeCommandAction Command="{Binding ViewModel.LoadImageCommand,
                                                                             RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}" />
                                </i:EventTrigger>
                                <i:EventTrigger EventName="Unloaded">
                                    <i:InvokeCommandAction Command="{Binding ViewModel.UnLoadImageCommand,
                                                                             RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </control:GameCard>
                    </DataTemplate>
                </ui:VirtualizingItemsControl.ItemTemplate>
            </ui:VirtualizingItemsControl>
        </Grid>
    </DockPanel>
</Page>