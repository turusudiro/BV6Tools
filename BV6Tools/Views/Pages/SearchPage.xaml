<Page x:Class="BV6Tools.Views.Pages.SearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:control="clr-namespace:BV6Tools.Views.Controls"
      xmlns:cv="clr-namespace:BV6Tools.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:local="clr-namespace:BV6Tools.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      x:Name="searchpage"
      Title="DataPage"
      d:DataContext="{d:DesignInstance local:SearchPage,
                                       IsDesignTimeCreatable=False}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="True"
      mc:Ignorable="d">
    <Page.Resources>
        <cv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ui:AutoSuggestBox Margin="0,0,0,12"
                           DisplayMemberPath="Name"
                           ItemsSource="{Binding ViewModel.Games}"
                           OriginalItemsSource="{Binding ViewModel.Games}"
                           PlaceholderText="Search By Name"
                           Text="{Binding ViewModel.Search,
                                          Mode=TwoWay}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="TextChanged">
                    <i:InvokeCommandAction Command="{Binding ViewModel.SearchTextChangedCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </ui:AutoSuggestBox>
        <control:GamesPagination x:Name="GamesPage"
                                 Grid.Row="1"
                                 ControlsPosition="Bottom"
                                 IsAutoSlideEnabled="False"
                                 ItemsSource="{Binding ViewModel.GamesView}">
            <control:GamesPagination.PaginationControls>
                <Grid Grid.Column="1"
                      Margin="0,12,0,0"
                      Visibility="{Binding CanScrollPages,
                                           RelativeSource={RelativeSource AncestorType=control:GamesPagination},
                                           Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:Button Click="GoToPreviousPage"
                               Icon="{ui:SymbolIcon Symbol=ArrowCircleLeft20,
                                                    FontSize=20}" />
                    <ui:Button Grid.Column="2"
                               Click="GoToNextPage"
                               Icon="{ui:SymbolIcon Symbol=ArrowCircleRight20,
                                                    FontSize=20}" />
                </Grid>
            </control:GamesPagination.PaginationControls>
            <control:GamesPagination.ItemTemplate>
                <DataTemplate>
                    <control:GameCard AddCommand="{Binding ViewModel.AddButtonGameCardCommand,
                                                           RelativeSource={RelativeSource AncestorType=Page}}"
                                      AddCommandParameter="{Binding}"
                                      DownloadCommand="{Binding ViewModel.DownloadButtonGameCardCommand,
                                                                RelativeSource={RelativeSource AncestorType=Page}}"
                                      DownloadCommandParameter="{Binding}"
                                      Text="{Binding Name}"
                                      ViewBoxMargin="{Binding ViewBoxMargin,
                                                              RelativeSource={RelativeSource AncestorType=control:GamesPagination}}"
                                      ViewBoxWidth="{Binding ViewBoxWidth,
                                                             RelativeSource={RelativeSource AncestorType=control:GamesPagination}}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Loaded">
                                <i:InvokeCommandAction Command="{Binding ViewModel.LoadImageCommand,
                                                                         RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" />
                            </i:EventTrigger>
                            <i:EventTrigger EventName="Unloaded">
                                <i:InvokeCommandAction Command="{Binding ViewModel.UnLoadImageCommand,
                                                                         RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </control:GameCard>
                </DataTemplate>
            </control:GamesPagination.ItemTemplate>
        </control:GamesPagination>
