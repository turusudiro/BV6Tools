<ui:ContentDialog x:Class="BV6Tools.Views.Dialogs.ProgressDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:local="clr-namespace:BV6Tools.Views.Dialogs"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  mc:Ignorable="d"
                  d:DesignHeight="450"
                  d:DesignWidth="800"
                  d:DataContext="{d:DesignInstance local:ProgressDialog,
                               IsDesignTimeCreatable=False}"
                  Title="{Binding Title}"
                  PrimaryButtonText="{Binding PrimaryButtonText}"
                  DialogMaxWidth="400"
                  CloseButtonText="Cancel">
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:ProgressDialog}" />
    </ui:ContentDialog.Resources>
    <Grid MinWidth="200">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <ui:TextBlock Margin="0,0,0,8"
                      Text="{Binding Progress.Text}" TextWrapping="WrapWithOverflow" />
        <ProgressBar Grid.Row="1"
                     Value="{Binding Progress.Value}"
                     Maximum="{Binding Progress.MaxValue}"
                     IsIndeterminate="{Binding Progress.IsIndeterminate}" />
    </Grid>
</ui:ContentDialog>