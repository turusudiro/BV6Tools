<ui:ContentDialog x:Class="BV6Tools.Views.Dialogs.InputDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:cv="clr-namespace:BV6Tools.Converters"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:local="clr-namespace:BV6Tools.Views.Dialogs"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  d:DataContext="{d:DesignInstance local:InputDialog,
                                                   IsDesignTimeCreatable=False}"
                  d:DesignHeight="450"
                  d:DesignWidth="800"
                  mc:Ignorable="d">
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type local:InputDialog}" />
        <cv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </ui:ContentDialog.Resources>
    <StackPanel MinWidth="300">
        <ui:TextBlock Margin="0,0,0,10"
                      Text="{Binding InputTitle}"
                      TextWrapping="WrapWithOverflow" />
        <ui:TextBox x:Name="TextBox"
                    PlaceholderText="{Binding PlaceHolderInputText}"
                    Text="{Binding InputText,
                                   UpdateSourceTrigger=PropertyChanged}"
                    Visibility="{Binding IsInputNumber,
                                         Converter={StaticResource BooleanToVisibilityConverter},
                                         ConverterParameter=True}" />
        <ui:NumberBox x:Name="NumberBox"
                      PlaceholderText="{Binding PlaceHolderInputText}"
                      Text="{Binding InputText,
                                     UpdateSourceTrigger=PropertyChanged}"
                      Visibility="{Binding IsInputNumber,
                                           Converter={StaticResource BooleanToVisibilityConverter}}" />
    </StackPanel>
</ui:ContentDialog>